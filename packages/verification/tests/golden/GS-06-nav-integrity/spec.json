      "packages/shared-ui/src/screens/HomeScreen.tsx",
      "packages/shared-ui/src/navigation/DrawerNavigator.tsx",
      "packages/shared-ui/src/navigation/RootNavigator.tsx",
      "packages/shared-ui/src/navigation/AppNavigator.tsx",
      "packages/shared-ui/src/navigation/types.ts",
      "apps/expo-multi-tv/App.tsx",
      "package.json"
    ],
    "nav_routes": ["Home", "Categories", "Search", "Settings"],
    "screen_count": 3,
    "focus_nodes_min": 3,
    "platforms_build": ["web"],
    "content_items_expected": 8
  }
}
